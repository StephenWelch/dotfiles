{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "qwen2.5-coder-32b": {
          "name": "Qwen2.5-Coder 32B (Q5_K_M, 32K ctx)"
        }
      }
    }
  },
  "model": "llama/qwen2.5-coder-32b",
  "mcp": {
    "beads": {
      "type": "local",
      "command": ["beads-mcp"],
      "enabled": true
    }
  }
}
